        },
        "cortex-m4": {
            "cpu_arch": "cortex-m4",
            "qemu_cpu": "cortex-m4",
            "qemu_machine": "mps2-an386",
            "description": "Cortex-M4 (e.g., STM32F4, STM32L4)"
        },
        "cortex-m7": {
            "cpu_arch": "cortex-m7",
            "qemu_cpu": "cortex-m7",
