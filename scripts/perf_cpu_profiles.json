    "spi_configs": [
        {"name": "no_spi", "buffer_count": 1, "spi_mhz": 0, "desc": "No SPI (CPU only)"},
        {"name": "spi16_buf2", "buffer_count": 2, "spi_mhz": 16, "desc": "16MHz SPI, dual buffer"},
        {"name": "spi64_buf2", "buffer_count": 2, "spi_mhz": 64, "desc": "64MHz SPI, dual buffer"}
