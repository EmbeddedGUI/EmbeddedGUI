        "fullwidth": {
            "pfb_width": 240,
            "pfb_height": 1,
            "description": "Full-width strip (SCREEN_WIDTH x 1, 240x1)"
        },
        "fullheight": {
            "pfb_width": 1,
            "pfb_height": 320,
            "description": "Full-height strip (1 x SCREEN_HEIGHT, 1x320)"
        },
        "fullscreen": {
            "pfb_width": 240,
            "pfb_height": 320,
            "description": "Full-screen (SCREEN_WIDTH x SCREEN_HEIGHT, 240x320)"
        }
