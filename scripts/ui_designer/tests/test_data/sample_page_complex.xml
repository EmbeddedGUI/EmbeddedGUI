<?xml version="1.0" encoding="utf-8"?>
<Page>
    <Group id="root_group" x="0" y="0" width="240" height="320">
        <LinearLayout id="main_layout" x="0" y="0" width="240" height="280" orientation="vertical" align_type="EGUI_ALIGN_CENTER">
            <Label id="title" x="0" y="0" width="200" height="30" text="@string/app_name" color="EGUI_COLOR_WHITE" />
            <Image id="logo" x="0" y="0" width="100" height="100" image_file="star.png" image_format="rgb565" image_alpha="4" />
            <Button id="action_btn" x="0" y="0" width="120" height="40" text="Click Me" onClick="on_action">
                <Background type="round_rectangle" color="EGUI_COLOR_BLUE" alpha="EGUI_ALPHA_100" radius="8" has_pressed="true" pressed_color="EGUI_COLOR_NAVY" pressed_alpha="EGUI_ALPHA_100" />
            </Button>
            <Switch id="toggle" x="0" y="0" width="60" height="30" is_checked="true" />
            <ProgressBar id="progress" x="0" y="0" width="200" height="20" value="75" />
        </LinearLayout>
    </Group>
</Page>
